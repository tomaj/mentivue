{
  "name": "@mentivue/workers",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=../../.env run --watch src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir=dist",
    "start": "bun run dist/index.js",
    "typecheck": "tsc --noEmit",
    "test:collect": "bun --env-file=../../.env run src/scripts/test-collect.ts",
    "analyze:pending": "bun --env-file=../../.env run src/scripts/analyze-pending.ts",
    "report:snapshot": "bun --env-file=../../.env run src/scripts/report-snapshot.ts",
    "schedule:demo": "bun --env-file=../../.env run src/scripts/schedule-demo.ts"
  },
  "dependencies": {
    "@mentivue/shared": "workspace:*",
    "bullmq": "^5.34.0",
    "drizzle-orm": "^0.38.0",
    "ioredis": "^5.4.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  }
}
