---
interface Props {
  tone?: 'ink' | 'paper';
  href?: string;
  size?: number;
}
const { tone = 'ink', href = '/', size = 48 } = Astro.props;
const stroke = tone === 'paper' ? '#F7F4ED' : '#0E1116';
---
<a class="logo" href={href} aria-label="mentivue — domov">
  <span class="logo-mark" aria-hidden="true">
    <svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" width={size} height={size}>
      <circle cx="24" cy="24" r="22" fill="none" stroke={stroke} stroke-width="2" />
      <path d="M 6 24 Q 24 6 42 24 Q 24 42 6 24 Z" fill="none" stroke={stroke} stroke-width="2" />
      <circle cx="24" cy="24" r="5" fill="#FF5B3A" />
    </svg>
  </span>
  <span class="logo-word">mentivue</span>
</a>
