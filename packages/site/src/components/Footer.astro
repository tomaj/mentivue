---
import Logo from './Logo.astro';
---
{/* Dual class names so both Homepage CSS (.footer, .footer-top, .footer-brand, .footer-cols, .footer-bot) and legal-template.css (footer.site, .ft-top, .brand, .cols, .ft-bot) apply correctly. */}
<footer class="footer site">
  <div class="container">
    <div class="footer-top ft-top">
      <div class="footer-brand brand">
        <Logo tone="paper" href="/" />
        <div class="tagline">Výskum pre <em>éru AI vyhľadávania.</em></div>
        <div class="roadmap">
          Dnes: <em>slovenský e-commerce.</em><br />
          Zajtra: bankovníctvo, retail, poistenie.
        </div>
      </div>

      <div class="footer-cols cols">
        <div class="footer-col">
          <h4>Produkt</h4>
          <ul>
            <li><a href="/#audit">Audit značky</a></li>
            <li><a href="/#pro">Pro predplatné</a></li>
            <li><a href="/#watch">Watch</a></li>
            <li><a href="/#report">Industry Report</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Firma</h4>
          <ul>
            <li><a href="/about">O nás</a></li>
            <li><a href="/methodology">Metodológia</a></li>
            <li><a href="/research">Výskum</a></li>
            <li><a href="mailto:tomas@mentivue.sk">Kontakt</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Právne</h4>
          <ul>
            <li><a href="/legal/terms">Podmienky</a></li>
            <li><a href="/legal/privacy">Súkromie</a></li>
            <li><a href="/legal/cookies">Cookies</a></li>
            <li><a href="/legal/dpa">DPA</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Kanály</h4>
          <ul>
            <li><a href="#li">LinkedIn</a></li>
            <li><a href="#x">X</a></li>
            <li><a href="mailto:hello@mentivue.sk">E-mail</a></li>
            <li><a href="/blog">Blog</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="footer-bot ft-bot">
      <span class="mono">Mentivue · Bratislava · 2026</span>
      <span class="mono">© MMXXVI · Všetky merania reprodukovateľné</span>
    </div>
  </div>
</footer>
