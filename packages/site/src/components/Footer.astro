          <ul>
            <li><a href="#li">LinkedIn</a></li>
            <li><a href="#x">X</a></li>
            <li><a href="#email">E-mail</a></li>
            <li><a href="/blog">Blog</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="footer-bot">
      <span class="mono">Mentivue · Bratislava · 2026</span>
      <span class="mono">© MMXXVI · Všetky merania reprodukovateľné</span>
