        <div class="roadmap">
          Dnes: <em>slovenský e-commerce.</em><br />
          Zajtra: bankovníctvo, retail, poistenie.
        </div>
      </div>

      <div class="footer-cols">
        <div class="footer-col">
          <h4>Produkt</h4>
          <ul>
            <li><a href="/#audit">Audit značky</a></li>
            <li><a href="/#pro">Pro predplatné</a></li>
            <li><a href="/#watch">Watch</a></li>
            <li><a href="/#report">Industry Report</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Firma</h4>
          <ul>
            <li><a href="/about">O nás</a></li>
            <li><a href="/methodology">Metodológia</a></li>
