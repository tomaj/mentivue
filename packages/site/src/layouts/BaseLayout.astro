---
import '../styles/tokens.css';
import '../styles/base.css';
import { SITE, absoluteUrl, organizationJsonLd, pageTitle, websiteJsonLd } from '../lib/site';

export interface Props {
  /** Page-specific title. Will be wrapped with site name unless it already contains it. */
  title?: string;
  description?: string;
  bodyClass?: string;
  /** Override the default 1200×630 OG image. Pass an absolute or root-relative path. */
  ogImage?: string;
  ogType?: 'website' | 'article';
  /** ISO 8601 dates for article pages. */
  publishedAt?: string;
  modifiedAt?: string;
  author?: string;
  keywords?: string[];
  /** Block search engines from indexing this page (e.g. drafts, internal). */
  noIndex?: boolean;
  /** Inject additional structured data blobs. Organization + WebSite are added automatically. */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = SITE.defaultDescription,
  bodyClass,
  ogImage = SITE.defaultOgImage,
  ogType = 'website',
  publishedAt,
  modifiedAt,
  author,
  keywords,
  noIndex = false,
  jsonLd,
} = Astro.props;

const fullTitle = pageTitle(title);
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? SITE.origin).toString();
const ogImageAbs = absoluteUrl(ogImage);

// Build JSON-LD: always include Organization + WebSite, then any per-page blobs.
const jsonLdBlobs: Record<string, unknown>[] = [organizationJsonLd(), websiteJsonLd()];
if (jsonLd) {
  if (Array.isArray(jsonLd)) jsonLdBlobs.push(...jsonLd);
  else jsonLdBlobs.push(jsonLd);
}
---
<!doctype html>
<html lang={SITE.langCode}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  {keywords && keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}
  <meta name="generator" content={Astro.generator} />

  {noIndex
    ? <meta name="robots" content="noindex,nofollow" />
    : <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1" />}

  <link rel="canonical" href={canonicalURL} />

  {/* Icons + theme */}
  <link rel="icon" type="image/svg+xml" href="/mentivue-logo.svg" />
  <link rel="apple-touch-icon" href="/mentivue-logo.svg" />
  <meta name="theme-color" content={SITE.themeColor} />
  <meta name="color-scheme" content="light" />

  {/* Open Graph */}
  <meta property="og:type" content={ogType} />
  <meta property="og:locale" content={SITE.locale} />
  <meta property="og:site_name" content={SITE.name} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={ogImageAbs} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={`${SITE.name} — ${description}`} />
  {ogType === 'article' && publishedAt && <meta property="article:published_time" content={publishedAt} />}
  {ogType === 'article' && modifiedAt && <meta property="article:modified_time" content={modifiedAt} />}
  {ogType === 'article' && author && <meta property="article:author" content={author} />}

  {/* Twitter / X */}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content={SITE.twitterHandle} />
  <meta name="twitter:creator" content={SITE.twitterHandle} />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageAbs} />

  {/* Fonts */}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400;1,9..144,500&family=Inter+Tight:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600&display=swap"
    rel="stylesheet"
  />

  {/* Sitemap + feed hints */}
  <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

  {/* JSON-LD structured data — Organization + WebSite (and any per-page blobs) */}
  {jsonLdBlobs.map((blob) => (
    <script type="application/ld+json" set:html={JSON.stringify(blob)} />
  ))}

  <slot name="head" />
</head>
<body class={bodyClass}>
  <slot />
</body>
</html>
