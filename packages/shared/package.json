{
  "name": "@mentivue/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./db": "./src/db/index.ts",
    "./db/queries": "./src/db/queries.ts",
    "./db/schema": "./src/db/schema.ts",
    "./llm": "./src/llm/index.ts",
    "./types": "./src/types/index.ts",
    "./utils": "./src/utils/index.ts",
    "./config": "./src/config/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun --env-file=../../.env run src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun --env-file=../../.env run src/db/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.97.0",
    "@google/genai": "^2.4.0",
    "drizzle-orm": "^0.45.2",
    "js-yaml": "^4.1.0",
    "langfuse": "^3.38.20",
    "openai": "^6.7.0",
    "postgres": "^3.4.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/js-yaml": "^4.0.9",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3"
  }
}
