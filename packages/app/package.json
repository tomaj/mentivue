{
  "name": "@mentivue/app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=../../.env run --watch src/server.ts",
    "build": "bun build src/server.ts --target=bun --outdir=dist",
    "start": "bun run dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mentivue/shared": "workspace:*",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  }
}
