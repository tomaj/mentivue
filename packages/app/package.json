{
  "name": "@mentivue/app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=../../.env run --watch src/server.ts",
    "build": "bun build src/server.ts --target=bun --outdir=dist",
    "start": "bun run dist/server.js",
    "test": "bun --env-file=../../.env test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.8.0",
    "@mentivue/shared": "workspace:*",
    "@sentry/bun": "^10.53.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.14",
    "ioredis": "^5.4.1",
    "nodemailer": "^8.0.7",
    "pino": "^10.3.1",
    "pino-pretty": "^13",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/nodemailer": "^8.0.0",
    "typescript": "^6.0.3"
  }
}
